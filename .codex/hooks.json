{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/skill-forced-eval.cjs",
            "statusMessage": "评估项目技能",
            "timeout": 12
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|shell|exec_command|functions\\.exec_command|apply_patch|functions\\.apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/pre-tool-use.cjs",
            "statusMessage": "执行前安全检查",
            "timeout": 12
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|shell|exec_command|functions\\.exec_command|apply_patch|functions\\.apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/workflow-event.cjs",
            "statusMessage": "记录工具执行摘要",
            "timeout": 12
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/workflow-event.cjs",
            "statusMessage": "记录流程收口信号",
            "timeout": 12
          }
        ]
      }
    ]
  }
}
