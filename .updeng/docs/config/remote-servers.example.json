{
  "defaults": {
    "audit_log": "tmp/remote-ops-audit.jsonl",
    "connect_timeout": 10,
    "command_timeout_sec": 60
  },
  "targets": {
    "dev-app-01": {
      "env": "dev",
      "host": "127.0.0.1",
      "port": 22,
      "user": "deploy",
      "identity_file": "C:/Users/your-user/.ssh/id_rsa",
      "ssh_backend": "auto",
      "security_mode": "safe",
      "paths": {
        "java_backend": "/opt/apps/java-backend",
        "logs": "/opt/apps/java-backend/logs"
      },
      "path_allowlist": [
        "/opt/apps/java-backend/logs",
        "/tmp"
      ],
      "command_aliases": {
        "app-status": "systemctl status app.service --no-pager",
        "app-log": "tail -n 200 /opt/apps/java-backend/logs/app.log",
        "disk": "df -h"
      },
      "description": "Example development server. Copy this file to remote-servers.json and fill local values."
    },
    "prod-app-readonly": {
      "env": "prod",
      "host": "198.51.100.20",
      "port": 22,
      "user": "observer",
      "identity_file": "C:/Users/your-user/.ssh/prod_readonly",
      "ssh_backend": "auto",
      "security_mode": "readonly",
      "paths": {
        "java_backend": "/opt/apps/java-backend",
        "logs": "/opt/apps/java-backend/logs"
      },
      "path_allowlist": [
        "/opt/apps/java-backend/logs"
      ],
      "deny_patterns": [
        "\\bsudo\\b",
        "\\brm\\b",
        "\\bsystemctl\\s+(restart|stop|start)"
      ],
      "command_aliases": {
        "app-status": "systemctl status app.service --no-pager",
        "app-log": "tail -n 200 /opt/apps/java-backend/logs/app.log",
        "ports": "ss -lntp"
      },
      "description": "Example production read-only diagnostic target."
    }
  }
}
