+  machineId?: string;
+  paneId?: string;
+  tabId?: string;
+}) {
+  if (ref.kind === "pane" && ref.paneId) {
+    return `pane:${ref.paneId}`;
+  }
+  if (ref.kind === "tab" && ref.tabId) {
+    return `tab:${ref.tabId}`;
+  }
+  if (ref.kind === "host" && ref.machineId) {
