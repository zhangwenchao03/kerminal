+    expect(apiMcp).toEqual(mcp);
+    expect(manifest.tools).toEqual(mcp);
+    expect(apiManifest.tools).toEqual(mcp);
+
+    const previewToolsById = new Map(
+      previewTools.map((tool) => [tool.id, tool] as const),
+    );
