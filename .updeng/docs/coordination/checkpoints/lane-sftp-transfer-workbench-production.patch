+            production: false,
+            ssh_options: Default::default(),
+            sort_order: 0,
+            created_at: "now".to_owned(),
+            updated_at: "now".to_owned(),
+        },
+        auth: SftpAuthMaterial::Password("secret".to_owned()),
+        known_hosts_path,
