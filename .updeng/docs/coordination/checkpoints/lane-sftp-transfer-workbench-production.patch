+    kind: "mkdir",
+    request: dockerPathRequest(fileTarget, path),
+    targetKind: "dockerContainer",
+  };
+}
+
+function buildRenameOperation(
+  fileTarget: SftpFileTarget,
+  fromPath: string,
+  toPath: string,
+): SftpDialogOperation {
+  if (fileTarget.kind === "ssh") {
+    return {
+      kind: "rename",
+      request: { fromPath, hostId: fileTarget.hostId, toPath },
+      targetKind: "ssh",
+    };
