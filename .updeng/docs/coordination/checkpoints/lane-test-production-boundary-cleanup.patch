-        keys: vec![host_key],
-        maximum_packet_size: 65_535,
-        ..Default::default()
-    };
-    let symlinks = Arc::new(
-        symlinks
-            .into_iter()
-            .map(|(link, target)| {
-                (
-                    normalize_loopback_remote_path(&link),
-                    normalize_loopback_remote_path(&target),
-                )
-            })
-            .collect(),
-    );
-    let task = tokio::spawn(async move {
-        let mut server = LoopbackSshServer { root, symlinks };
