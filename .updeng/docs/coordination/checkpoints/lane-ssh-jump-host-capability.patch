+    assert_eq!(restored.status, PortForwardStatus::Exited);
+    assert_eq!(restored.pid, None);
+    assert_eq!(restored.shared_proxy_service_id, None);
+    assert_eq!(restored.local_proxy_entry_id, None);
+    assert_eq!(
