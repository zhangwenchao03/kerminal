[
  {
    "id": "putty-password-basic",
    "priority": "P0",
    "sourceTool": "putty",
    "entrypoint": "direct-argv",
    "argv": [
      "putty.exe",
      "-ssh",
      "ops@example.internal",
      "-P",
      "2222",
      "-pw",
      "KERM_FIXTURE_PASSWORD_DO_NOT_USE"
    ],
    "expected": {
      "target": {
        "host": "example.internal",
        "port": 2222,
        "username": "ops"
      },
      "auth": {
        "passwordRef": true
      },
      "options": {
        "displayName": "ops@example.internal"
      },
      "diagnostics": {
        "redactedArgv": [
          "putty.exe",
          "-ssh",
          "ops@example.internal",
          "-P",
          "2222",
          "-pw",
          "<redacted>"
        ],
        "redactedNotContains": [
          "KERM_FIXTURE_PASSWORD_DO_NOT_USE"
        ]
      }
    }
  },
  {
    "id": "putty-session-key-command",
    "priority": "P1",
    "sourceTool": "putty",
    "entrypoint": "direct-argv",
    "argv": [
      "putty.exe",
      "-load",
      "prod-app",
      "-ssh",
      "app.internal",
      "-l",
      "deploy",
      "-P",
      "22",
      "-i",
      "C:\\Users\\alice\\.ssh\\prod.ppk",
      "-m",
      "C:\\Temp\\remote-command.txt"
    ],
    "expected": {
      "target": {
        "host": "app.internal",
        "port": 22,
        "username": "deploy"
      },
      "auth": {
        "identityFile": "C:\\Users\\alice\\.ssh\\prod.ppk"
      },
      "options": {
        "displayName": "prod-app",
        "remoteCommandFile": "C:\\Temp\\remote-command.txt"
      },
      "diagnostics": {
        "redactedArgv": [
          "putty.exe",
          "-load",
          "prod-app",
          "-ssh",
          "app.internal",
          "-l",
          "deploy",
          "-P",
          "22",
          "-i",
          "<path:fingerprint>",
          "-m",
          "<path:fingerprint>"
        ],
        "redactedNotContains": []
      }
    }
  },
  {
    "id": "putty-password-file",
    "priority": "P1",
    "sourceTool": "putty",
    "entrypoint": "direct-argv",
    "argv": [
      "putty.exe",
      "-ssh",
      "backup@backup.internal",
      "-P",
      "2200",
      "-pwfile",
      "C:\\Temp\\kerminal-fixture-password.txt"
    ],
    "sidecarFiles": {
      "C:\\Temp\\kerminal-fixture-password.txt": "KERM_FIXTURE_PASSFILE_SECRET_DO_NOT_USE\n"
    },
    "expected": {
      "target": {
        "host": "backup.internal",
        "port": 2200,
        "username": "backup"
      },
      "auth": {
        "passwordRef": true,
        "passwordFile": "C:\\Temp\\kerminal-fixture-password.txt"
      },
      "options": {
        "displayName": "backup@backup.internal"
      },
      "diagnostics": {
        "redactedArgv": [
          "putty.exe",
          "-ssh",
          "backup@backup.internal",
          "-P",
          "2200",
          "-pwfile",
          "<path:fingerprint>"
        ],
        "redactedNotContains": [
          "KERM_FIXTURE_PASSFILE_SECRET_DO_NOT_USE"
        ]
      }
    }
  },
