{
  "name": "kerminal",
  "private": true,
  "version": "0.3.7",
  "type": "module",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "dev:force": "vite --force",
    "check:architecture": "node scripts/check-frontend-architecture.mjs --output .updeng/docs/verification/frontend-architecture.json",
    "check:dead-code": "node scripts/check-dead-code.mjs --output .updeng/docs/verification/dead-code.json",
    "check:source-size": "node scripts/check-source-size.mjs --output .updeng/docs/verification/source-size.json",
    "lint": "node scripts/check-eslint.mjs --output .updeng/docs/verification/eslint.json",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest",
    "test:frontend": "vitest run",
    "test:terminal-ghost": "vitest run tests/frontend/features/terminal/terminalInputModel.test.ts tests/frontend/features/terminal/XtermPane.test.tsx tests/frontend/lib/terminalSuggestionApi.test.ts",
    "test:terminal-renderer-lifecycle": "vitest run tests/frontend/features/terminal/terminalRendererLifecycle.test.ts tests/frontend/features/terminal/terminalRenderer.test.ts tests/frontend/features/terminal/terminalRendererHealth.test.ts",
    "test:rust": "cd src-tauri && cargo test",
    "test:quality-gates": "node --test tests/scripts/check-frontend-architecture.test.mjs tests/scripts/check-eslint.test.mjs tests/scripts/check-dead-code.test.mjs tests/scripts/public-contract-inventory.test.mjs",
    "test:source-size": "node --test tests/scripts/check-source-size.test.mjs",
    "test:windows-release-package": "node --test tests/scripts/windows-release-package.test.mjs",
    "smoke:ssh-suggestions": "node scripts/smoke-ssh-command-suggestions.mjs",
    "smoke:ssh-suggestions:loopback": "node scripts/smoke-ssh-command-suggestions-loopback.mjs",
    "smoke:ssh-suggestions:wsl": "node scripts/smoke-ssh-command-suggestions-wsl.mjs",
    "smoke:ssh-suggestions:wsl:posix": "node scripts/smoke-ssh-command-suggestions-wsl.mjs --posix-only",
    "smoke:ssh-terminal:password": "node scripts/smoke-ssh-terminal-password.mjs",
    "smoke:ssh-terminal:password:loopback": "cd src-tauri && cargo test --test ssh_terminal_password_smoke local_russh_loopback -- --nocapture",
    "smoke:ssh-terminal:password:wsl": "node scripts/smoke-ssh-command-suggestions-wsl.mjs --terminal-password",
    "smoke:ssh-terminal:password:wsl:wrong": "node scripts/smoke-ssh-command-suggestions-wsl.mjs --terminal-password-wrong",
    "verify:terminal-ghost-frame": "node scripts/verify-terminal-ghost-frame-budget.mjs",
    "verify:terminal-ghost-visual": "node scripts/verify-terminal-ghost-visual.mjs",
    "verify:terminal-ghost-xterm": "node scripts/verify-terminal-ghost-real-xterm.mjs",
    "verify:terminal-ghost-app": "node scripts/verify-terminal-ghost-app.mjs",
    "verify:terminal-gpu-recovery": "node scripts/verify-terminal-gpu-recovery-smoke.mjs",
    "verify:terminal-renderer-settings": "node scripts/verify-terminal-renderer-settings-smoke.mjs",
    "verify:terminal-renderer-faults": "node scripts/verify-terminal-renderer-faults.mjs",
    "verify:terminal-renderer-lifecycle-stress": "node scripts/verify-terminal-renderer-lifecycle-stress.mjs",
    "verify:terminal-renderer-platform-matrix": "node scripts/verify-terminal-renderer-platform-matrix.mjs",
    "verify:terminal-renderer-windows-hitl-preflight": "node scripts/verify-terminal-renderer-windows-hitl-preflight.mjs",
    "verify:terminal-renderer-soak": "node scripts/verify-terminal-renderer-soak.mjs",
    "verify:terminal-command-block-rail": "node scripts/verify-terminal-command-block-rail.mjs",
    "verify:managed-ssh-auto": "node scripts/verify-managed-ssh-auto.mjs",
    "verify:managed-ssh-hitl": "node scripts/verify-managed-ssh-hitl.mjs",
    "verify:tauri-desktop-plugins:macos": "node scripts/verify-tauri-desktop-plugins-macos.mjs",
    "verify:external-launch-security": "cd src-tauri && cargo test --test external_launch_deep_link --test external_launch_parser --test external_launch_commands",
    "verify:external-launch-responsiveness": "cd src-tauri && cargo test --test external_launch_intake --test external_launch_smoke_matrix --test ssh_terminal_command",
    "verify:windows-release-package": "node scripts/verify-windows-release-package.mjs",
    "verify:command-suggestion-latency": "cd src-tauri && cargo test --test command_suggestion_performance command_suggestion_mixed_provider_latency_gate -- --exact --nocapture",
    "perf:frontend-bundle": "pnpm run build && node scripts/report-frontend-bundle.mjs",
    "perf:rust-timings": "cd src-tauri && cargo build --timings",
    "perf:terminal-input": "node scripts/perf-terminal-input.mjs",
    "perf:terminal-output": "node scripts/perf-terminal-output.mjs",
    "perf:terminal-renderer": "node scripts/perf-terminal-renderer.mjs",
    "perf:terminal-report": "node scripts/perf-terminal-output-report.mjs",
    "perf:directory-list": "node scripts/perf-directory-list.mjs",
    "perf:collect-baseline": "node scripts/perf-collect-baseline.mjs",
    "audit:ui-content-density": "node scripts/audit-ui-content-density.mjs",
    "docs:capture-readme-screenshots": "node scripts/capture-readme-screenshots.mjs",
    "perf:baseline": "pnpm run perf:frontend-bundle && pnpm run perf:directory-list && pnpm run perf:terminal-output && pnpm run perf:collect-baseline",
    "check:terminal-ghost": "pnpm run verify:terminal-ghost-frame && pnpm run verify:terminal-ghost-visual && pnpm run verify:terminal-ghost-xterm && pnpm run verify:terminal-ghost-app",
    "check:ssh-command-ghost": "pnpm run test:terminal-ghost && pnpm run verify:command-suggestion-latency && pnpm run smoke:ssh-suggestions:loopback && pnpm run smoke:ssh-terminal:password:loopback && pnpm run check:terminal-ghost",
    "check:rust": "cd src-tauri && cargo fmt --check && cargo clippy --all-targets --all-features -- -D warnings && cargo test -j 1",
    "check": "pnpm run test:source-size && pnpm run test:quality-gates && pnpm run check:source-size && pnpm run check:architecture && pnpm run lint && pnpm run check:dead-code && pnpm run typecheck:test && pnpm run test:windows-release-package && pnpm run test:frontend && pnpm run check:rust && pnpm run build",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:unsigned": "tauri build --no-sign --config scripts/tauri.unsigned.conf.json"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.1.2",
    "react-resizable-panels": "^4.11.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "esbuild": "^0.27.7",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  }
}
