{
  "name": "kerminal",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:force": "vite --force",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:frontend": "vitest run",
    "test:terminal-ghost": "vitest run src/features/terminal/terminalInputModel.test.ts src/features/terminal/XtermPane.test.tsx src/lib/terminalSuggestionApi.test.ts",
    "test:rust": "cd src-tauri && cargo test",
    "smoke:ssh-suggestions": "node scripts/smoke-ssh-command-suggestions.mjs",
    "smoke:ssh-suggestions:loopback": "node scripts/smoke-ssh-command-suggestions-loopback.mjs",
    "smoke:ssh-suggestions:wsl": "node scripts/smoke-ssh-command-suggestions-wsl.mjs",
    "smoke:ssh-suggestions:wsl:posix": "node scripts/smoke-ssh-command-suggestions-wsl.mjs --posix-only",
    "smoke:ssh-terminal:password": "node scripts/smoke-ssh-terminal-password.mjs",
    "smoke:ssh-terminal:password:loopback": "cd src-tauri && cargo test --test ssh_terminal_password_smoke local_russh_loopback -- --nocapture",
    "smoke:ssh-terminal:password:wsl": "node scripts/smoke-ssh-command-suggestions-wsl.mjs --terminal-password",
    "smoke:ssh-terminal:password:wsl:wrong": "node scripts/smoke-ssh-command-suggestions-wsl.mjs --terminal-password-wrong",
    "verify:terminal-ghost-frame": "node scripts/verify-terminal-ghost-frame-budget.mjs",
    "verify:terminal-ghost-visual": "node scripts/verify-terminal-ghost-visual.mjs",
    "verify:terminal-ghost-xterm": "node scripts/verify-terminal-ghost-real-xterm.mjs",
    "verify:terminal-ghost-app": "node scripts/verify-terminal-ghost-app.mjs",
    "verify:command-suggestion-latency": "cd src-tauri && cargo test --test command_suggestion_performance command_suggestion_mixed_provider_latency_gate -- --exact --nocapture",
    "check:terminal-ghost": "npm run verify:terminal-ghost-frame && npm run verify:terminal-ghost-visual && npm run verify:terminal-ghost-xterm && npm run verify:terminal-ghost-app",
    "check:ssh-command-ghost": "npm run test:terminal-ghost && npm run verify:command-suggestion-latency && npm run smoke:ssh-suggestions:loopback && npm run smoke:ssh-terminal:password:loopback && npm run check:terminal-ghost",
    "check:rust": "cd src-tauri && cargo fmt --check && cargo clippy --all-targets --all-features -- -D warnings && cargo test",
    "check": "npm run test:frontend && npm run check:rust && npm run build",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.23",
    "@assistant-ui/react-streamdown": "^0.3.4",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-arborist": "^3.10.5",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.1.2",
    "react-resizable-panels": "^4.11.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  }
}
